{
  "name": "dcf-frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --configuration development",
    "start:prod": "ng serve --configuration production",
    "build": "ng build --configuration production",
    "build:dev": "ng build --configuration development",
    "build:cf": "npm run build && cp dist/dcf-frontend/browser/index.prod.html dist/dcf-frontend/browser/index.html",
    "test": "ng test",
    "serve:dev": "ng serve --configuration development",
    "docker:build": "docker build -f dockerfiles/frontend/Dockerfile -t stockvaluation-frontend:prod .",
    "docker:build:dev": "docker build -f dockerfiles/frontend/Dockerfile.dev -t stockvaluation-frontend:dev .",
    "docker:prod": "docker run -p 80:81 -e NODE_ENV=production --env-file .env stockvaluation-frontend:prod",
    "docker:dev": "docker run -p 80:81 -e NODE_ENV=development --env-file .env stockvaluation-frontend:dev",
    "deploy:cf": "npm run build:cf && CLOUDFLARE_ACCOUNT_ID=a06e3d15d8f9c538c49e8ce3454b660a wrangler pages deploy dist/dcf-frontend/browser --project-name stockvaluation --branch main --commit-dirty=true"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^19.2.14",
    "@angular/common": "^19.2.14",
    "@angular/compiler": "^19.2.14",
    "@angular/core": "^19.2.14",
    "@angular/forms": "^19.2.14",
    "@angular/platform-browser": "^19.2.14",
    "@angular/platform-browser-dynamic": "^19.2.14",
    "@angular/router": "^19.2.14",
    "@auth0/angular-jwt": "^5.2.0",
    "@ng-icons/core": "^31.4.0",
    "@ng-icons/heroicons": "^31.4.0",
    "@ng-icons/huge-icons": "^32.0.0",
    "@ng-icons/lucide": "^31.4.0",
    "@ng-icons/tabler-icons": "^31.4.0",
    "@semantic-components/re-captcha": "^0.42.0",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/postcss": "^4.1.8",
    "@tailwindcss/typography": "^0.5.16",
    "chart.js": "^4.4.9",
    "ngx-markdown": "^19.0.0",
    "ngx-sonner": "^3.1.0",
    "marked": "^15.0.0",
    "katex": "^0.16.11",
    "postcss": "^8.5.4",
    "primeicons": "^7.0.0",
    "primeng": "^19.1.3",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.1.8",
    "tslib": "^2.3.0",
    "vanilla-cookieconsent": "^3.0.0",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.15",
    "@angular/cli": "^19.2.15",
    "@angular/compiler-cli": "^19.2.14",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^18.18.0",
    "cors": "^2.8.5",
    "jasmine-core": "~5.2.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.5.2",
    "uuid": "^9.0.1"
  }
}