# Stock Valuation Agent environment template
# Copy to .env and set only the providers you plan to use.

# =============================================================================
# App
# =============================================================================
FLASK_ENV=production
FLASK_DEBUG=false
LOG_LEVEL=INFO
SECRET_KEY=

# =============================================================================
# Java valuation service
# =============================================================================
# Preferred explicit endpoint used by valuation_service_client
VALUATION_SERVICE_URL=http://localhost:8080/api/v1/automated-dcf-analysis
# Optional fallback base URL if VALUATION_SERVICE_URL is not set
VALUATION_SERVICE_BASE_URL=http://localhost:8080
# HTTP timeout (seconds) for valuation-service requests
VALUATION_SERVICE_TIMEOUT_SECONDS=180

# =============================================================================
# LLM routing
# =============================================================================
# Provider selection:
# - If DEFAULT_LLM_PROVIDER is unset, provider is auto-detected from configured keys.
# - Optional role overrides:
#   AGENT_LLM_PROVIDER for normal agent calls
#   JUDGE_LLM_PROVIDER for judge/adjudication calls
# - Optional role model overrides:
#   AGENT_LLM_MODEL / JUDGE_LLM_MODEL
DEFAULT_LLM_PROVIDER=
AGENT_LLM_PROVIDER=
JUDGE_LLM_PROVIDER=
AGENT_LLM_MODEL=
JUDGE_LLM_MODEL=

# Optional provider credentials
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_NAME=stockvaluation-io
OPENROUTER_SITE_URL=

# Optional JSON overrides (use-case behavior only)
# AGENT_USE_CASE_JSON={"narrative":"structured_json","segments":"strict_json"}
# AGENT_ROLE_JSON={"segments_judge":"judge"}
# USE_CASE_CONFIG_JSON={"strict_json":{"temperature":0.0,"model_kwargs":{"response_format":{"type":"json_object"}}}}
# MODEL_MAX_TOKENS_JSON={"gpt-4o-mini":8192}

# Optional provider backend specs for custom providers
# LLM_PROVIDER_SPECS_JSON={"together":{"backend":"openai","api_key_env":"TOGETHER_API_KEY","base_url_env":"TOGETHER_BASE_URL"}}

# News retrieval
MAX_NEWS_RESULTS=5

# =============================================================================
# Feature flags
# =============================================================================
ENABLE_LLM_GUARD=false

# =============================================================================
# Prompt dumps
# =============================================================================
# Optional: set AUTO_ENABLE_GEMINI_DUMPS=true to auto-enable dumps when GEMINI_API_KEY is present.
AUTO_ENABLE_GEMINI_DUMPS=true
DUMP_PROMPTS=
DUMP_LLM_RESPONSES=true
DUMP_PROCESSING_STEPS=false
PROMPT_DUMP_DIR=.etl/prompt_dump

# =============================================================================
# Cache
# =============================================================================
CACHE_TTL_HOURS=24

# =============================================================================
# Rate limiting
# =============================================================================
RATE_LIMIT_REQUESTS_PER_SECOND=2
RATE_LIMIT_DURATION_SECONDS=1
